generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Artwork {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  medium        String
  dimensions    String
  year          Int
  price         Int
  originalPrice Int?
  description   String
  gradient      String
  imageUrl      String?
  aspectRatio   String   @default("3/4")
  badge         String?
  collection    String?
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]
  @@index([category])
  @@index([collection])
  @@index([slug])
}

// Generic product for Jewellery, Clothing, Home Decor
model Product {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  type          String   // "jewellery" | "clothing" | "home-decor"
  description   String
  price         Int
  originalPrice Int?
  imageUrl      String?
  gradient      String   @default("linear-gradient(135deg, #667eea, #764ba2)")
  badge         String?  // "new" | "sold" | "featured"
  material      String?  // e.g. "Sterling Silver", "Cotton", etc.
  sizes         String?  // e.g. "S, M, L, XL" for clothing
  inStock       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([slug])
}

// Books with PDF and Amazon URL
model Book {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  author      String   @default("Chinmayi")
  description String
  price       Int?
  imageUrl    String?  // cover image
  pdfUrl      String?  // uploaded PDF
  amazonUrl   String?  // Amazon purchase link
  gradient    String   @default("linear-gradient(135deg, #667eea, #764ba2)")
  badge       String?  // "new" | "bestseller"
  pages       Int?
  isbn        String?
  publishYear Int?
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Collection {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  gradient    String
  sortOrder   Int    @default(0)
  createdAt   DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  customerName  String
  customerEmail String
  total       Int
  status      String      @default("pending")
  shippingAddress String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  artworkId String
  price     Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artwork   Artwork @relation(fields: [artworkId], references: [id])

  @@index([orderId])
  @@index([artworkId])
}

model Testimonial {
  id             String @id @default(cuid())
  name           String
  role           String
  text           String
  avatar         String
  avatarGradient String
  sortOrder      Int    @default(0)
  createdAt      DateTime @default(now())
}

model SiteSettings {
  id    String @id @default("main")
  heroTitle     String @default("Where Art Meets Soul")
  heroSubtitle  String @default("Discover breathtaking original paintings and limited-edition prints.")
  artistName    String @default("Chinmayi")
  artistBio     String @default("")
  contactEmail  String @default("hello@chinmayigallery.com")
  instagramUrl  String @default("")
  pinterestUrl  String @default("")
  facebookUrl   String @default("")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
